// prisma/schema.prisma

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  role          String         // 'ADMIN', 'MANAGER', 'SALES_REP'
  avatarUrl     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  calls         Call[]
  comments      CallComment[]
  notifications Notification[]
  apiKeys       ApiKey[]
}

model Call {
  id                    String              @id @default(uuid())
  title                 String
  clientName            String              @default("Unknown Client")
  salesRepId            String?
  salesRep              User?               @relation(fields: [salesRepId], references: [id])
  date                  DateTime            @default(now())
  duration              Int                 // in seconds
  status                String              // 'COMPLETED', 'LIVE', 'PROCESSING'
  overallSentiment      String              // 'Positive', 'Neutral', 'Negative'
  averageScore          Float
  averageEnergy         Float
  averageConfidence     Float
  conversionProbability Int                 // 0-100 percentage
  summary               String              // AI summary
  isFavorite            Boolean             @default(false)
  isSoftDeleted         Boolean             @default(false)
  
  // BANT Analysis fields
  bantBudget            String?
  bantBudgetMet         Boolean             @default(false)
  bantAuthority         String?
  bantAuthorityMet      Boolean             @default(false)
  bantNeed              String?
  bantNeedMet           Boolean             @default(false)
  bantTimeline          String?
  bantTimelineMet       Boolean             @default(false)
  
  // Relations
  records               EngagementRecord[]
  nextSteps             NextStep[]
  comments              CallComment[]
  
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

model EngagementRecord {
  id               String   @id @default(uuid())
  callId           String
  call             Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  timestamp        Float
  score            Int
  transcript       String
  sentiment        String
  buyingSignals    String   // JSON string of string[]
  hesitations      String   // JSON string of string[]
  detectedIntents  String   // JSON string of string[]
  intentConfidence Float
  recommendation   String
  energy           Float
  confidence       Float
  speaker          String
  createdAt        DateTime @default(now())
}

model NextStep {
  id          String    @id @default(uuid())
  callId      String
  call        Call      @relation(fields: [callId], references: [id], onDelete: Cascade)
  title       String
  description String
  isCompleted Boolean   @default(false)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CallComment {
  id        String   @id @default(uuid())
  callId    String
  call      Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  timestamp Float?   // relative time in call (in seconds)
  createdAt DateTime @default(now())
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  type        String   // 'INFO', 'WARNING', 'SUCCESS', 'ERROR'
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ApiKey {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  key       String   @unique
  createdAt DateTime @default(now())
}

model Integration {
  id        String   @id @default(uuid())
  name      String   @unique // 'Slack', 'Salesforce', 'HubSpot'
  connected Boolean  @default(false)
  config    String   // JSON string
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())
}
